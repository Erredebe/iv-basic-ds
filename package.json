{
  "name": "iv-basic-ds-monorepo",
  "version": "0.0.1",
  "description": "Design system base construido con StencilJS.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.cjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "npm run start --workspace @iv-basic-ds/docs",
    "start:showcase": "npm run start --workspace @iv-basic-ds/showcase",
    "build": "npm run build --workspaces --if-present",
    "build:showcase": "npm run build --workspace @iv-basic-ds/showcase",
    "build:packages": "npm run build --workspace @iv-basic-ds/iv-button && npm run build --workspace @iv-basic-ds/iv-icon && npm run build --workspace @iv-basic-ds/iv-input && npm run build --workspace @iv-basic-ds/iv-textarea && npm run build --workspace @iv-basic-ds/iv-dialog",
    "storybook": "npm run storybook --workspace @iv-basic-ds/docs",
    "build:storybook": "npm run build:storybook --workspace @iv-basic-ds/docs",
    "build:netlify": "node scripts/build-netlify.cjs",
    "copy:coverage": "node scripts/copy-coverage.cjs",
    "test:spec": "npm run test:spec --workspaces --if-present",
    "install:playwright": "playwright install chromium",
    "test:a11y": "npm run test:a11y --workspace @iv-basic-ds/docs",
    "test:a11y:build": "npm run build:netlify && npm run test:a11y",
    "deploy:netlify": "npm run test:spec && npm run build:netlify && npm run copy:coverage && npm run install:playwright && npm run test:a11y",
    "test": "npm run test:spec && npm run test:a11y",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@stencil/core": "latest",
    "dialog-polyfill": "^0.5.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@stencil/vitest": "^1.11.6",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/web-components": "latest",
    "@storybook/web-components-vite": "latest",
    "@vitest/coverage-v8": "^4.1.5",
    "@changesets/cli": "^2.29.7",
    "concurrently": "latest",
    "eslint": "^10.3.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "lit": "latest",
    "storybook": "latest",
    "storybook-addon-pseudo-states": "^10.3.6",
    "storybook-addon-tag-badges": "^3.1.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
