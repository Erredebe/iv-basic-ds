{
  "name": "@iv-basic-ds/showcase",
  "version": "0.0.1",
  "description": "Showcase Angular de IV Basic DS.",
  "private": true,
  "scripts": {
    "prestart": "npm run build --workspace @iv-basic-ds/docs",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "prebuild": "npm run build --workspace @iv-basic-ds/docs",
    "build": "ng build && node ../../scripts/copy-showcase-assets.cjs",
    "build:netlify": "ng build --configuration production && node ../../scripts/copy-showcase-assets.cjs"
  },
  "dependencies": {
    "@angular/common": "^20.3.14",
    "@angular/compiler": "^20.3.14",
    "@angular/core": "^20.3.14",
    "@angular/platform-browser": "^20.3.14",
    "@angular/router": "^20.3.14",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.11",
    "@angular/cli": "^20.3.11",
    "@angular/compiler-cli": "^20.3.14"
  }
}
